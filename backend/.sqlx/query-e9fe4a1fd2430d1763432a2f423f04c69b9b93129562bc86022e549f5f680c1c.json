{
  "db_name": "SQLite",
  "query": "\n        SELECT u.id,\n               u.display_name,\n               u.email,\n               COALESCE(\n                 (SELECT GROUP_CONCAT(provider, ',' ORDER BY created_at)\n                  FROM user_oauth_identities WHERE user_id = u.id),\n                 ''\n               ) AS \"providers!: String\",\n               u.created_at AS \"created_at!: String\",\n               (SELECT COUNT(*) FROM user_notices WHERE user_id = u.id) AS \"notice_count!: i64\"\n        FROM users u\n        WHERE u.id = ?\n        ",
