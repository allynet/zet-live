  "query": "\n        SELECT n.id              AS \"id!: String\",\n               n.user_id         AS \"user_id!: String\",\n               u.email,\n               u.display_name,\n               n.text            AS \"text!: String\",\n               n.severity        AS \"severity!: String\",\n               n.created_at      AS \"created_at!: String\"\n        FROM user_notices n\n        LEFT JOIN users u ON u.id = n.user_id\n        ORDER BY n.created_at DESC\n        ",
