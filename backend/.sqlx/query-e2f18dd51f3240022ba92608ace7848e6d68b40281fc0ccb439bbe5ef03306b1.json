  "query": "\n                    SELECT DISTINCT\n                        st.stop_id\n                        , s.latitude\n                        , s.longitude\n                    FROM gtfs_stop_times st\n                    LEFT JOIN gtfs_stops s on s.stop_id = st.stop_id\n                    WHERE\n                        trip_id = ?\n                    GROUP BY st.stop_id\n                    ORDER BY st.stop_sequence\n                    ",
