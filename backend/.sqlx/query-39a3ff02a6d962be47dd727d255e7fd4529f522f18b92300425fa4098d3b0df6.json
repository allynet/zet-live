  "query": "\n        SELECT u.id,\n               u.display_name,\n               u.email,\n               COALESCE(\n                 (SELECT GROUP_CONCAT(provider, ',' ORDER BY created_at)\n                  FROM user_oauth_identities WHERE user_id = u.id),\n                 ''\n               ) AS \"providers!: String\"\n        FROM users u\n        ORDER BY u.created_at DESC\n        ",
