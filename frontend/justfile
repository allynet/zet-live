set dotenv-load
set positional-arguments

default:
    @just --list

build:
    bun run build

dev:
    bun run dev

[parallel]
lint: type-check _lint

[parallel]
check: lint fmt-check

_lint:
    bun run lint

lint-check:
    bun run lint

fmt:
    bun run format

fmt-check:
    bun run format:check

type-check:
    bun run --bun tsc --noEmit

preview: build
    bun run preview
